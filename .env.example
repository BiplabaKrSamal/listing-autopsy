# ─────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your API keys.
# The .env file is loaded automatically by python-dotenv.
# Never commit your real .env to git.
# ─────────────────────────────────────────────────────────────

# Anthropic Claude API key
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Keepa Product API key
# Get one at: https://keepa.com/api
# Free tier: 250 tokens/day (~5 ASINs)
# Paid tier: $19/month for 20,000 tokens
KEEPA_API_KEY=YOUR_KEEPA_KEY_HERE

# Flask server port (optional, defaults to 5000)
PORT=5000
